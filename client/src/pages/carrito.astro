---
import BarraPaginaCarrito from "../components/barraCarrito/BarraPaginaCarrito";
import CarritoMap from "../components/carrito/CarritoMap";
import ModuloCerrado from "../components/Cerrado/ModuloCerrado.astro";
import PrincipalLayaout from "../layouts/PrincipalLayaout.astro";
import { cerrado } from "../productos";
---

<PrincipalLayaout
  title="Carrito de Compras"
  description="La Emiliana tienda de productos alimenticios"
  img_url="  favicons/web-app-manifest-512x512.png"
  url="https://www.tiendalaemiliana.com"
>
  <div class="relative ml-1 mt-5">
    <h2 class="ml-1 font-bold text-2xl">Carrito de Compras</h2>
    <div
      class="-z-10 bg-green-500 w-40 h-10 absolute -top-1 rounded-br-xl rounded-tr-xl overflow-visible"
    >
    </div>
  </div>
 {cerrado ? <ModuloCerrado/> :  <CarritoMap client:visible />}
  <BarraPaginaCarrito client:visible />
</PrincipalLayaout>
